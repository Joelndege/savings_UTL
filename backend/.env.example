# Django Core Settings
DJANGO_SECRET_KEY=replace-with-your-generated-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-app.up.railway.app,localhost

# Database Settings
DB_ENGINE=django.db.backends.postgresql
DB_NAME=railway_db_name           # Railway provides this in the dashboard
DB_USER=railway_db_user           # Railway PostgreSQL username
DB_PASSWORD=railway_db_password   # Railway PostgreSQL password
DB_HOST=railway_db_host           # Railway PostgreSQL host (URL)
DB_PORT=5432

# CORS Settings (Optional, if frontend is separate)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Static & Media Settings
STATIC_URL=/static/
MEDIA_URL=/media/